# =============================================================================
# Sunschool — Local E2E Testing Environment Template
# =============================================================================
# Copy this file to .env.test and fill in the values before running E2E tests.
#
#   cp .env.test.example .env.test
#
# Then run tests with:
#   PLAYWRIGHT_BASE_URL=http://localhost:5000 npx playwright test tests/e2e/
#
# Or against production:
#   PLAYWRIGHT_BASE_URL=https://sunschool.xyz npx playwright test tests/e2e/
# =============================================================================

# -----------------------------------------------------------------------------
# Required — Server will not start without these
# -----------------------------------------------------------------------------

# PostgreSQL connection string (local or remote)
# For local Postgres: postgresql://postgres:postgres@localhost:5432/sunschool_test
# For Docker:         postgresql://postgres:postgres@localhost:5432/sunschool_test
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sunschool_test"

# -----------------------------------------------------------------------------
# Required for AI-powered lesson generation
# -----------------------------------------------------------------------------

# LLM provider: 'openrouter' (default), 'bittensor', or 'perplexity'
LLM_PROVIDER="openrouter"

# OpenRouter API key — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-..."

# -----------------------------------------------------------------------------
# Authentication & Security
# -----------------------------------------------------------------------------

# Secret for signing session cookies (any random string)
SESSION_SECRET="test-session-secret-change-me"

# Secret for signing JWT tokens (falls back to SESSION_SECRET if not set)
JWT_SECRET="test-jwt-secret-change-me"

# JWT token expiry duration
# JWT_EXPIRY="7d"

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Port the dev server listens on (default: 5000)
# PORT=5000

# Node environment
NODE_ENV="development"

# Base URL for share links (optional, used for award sharing)
# APP_BASE_URL="http://localhost:5000"

# Database SSL — disable for local Postgres
DATABASE_SSL="false"

# -----------------------------------------------------------------------------
# Playwright-specific
# -----------------------------------------------------------------------------

# Base URL for Playwright tests (also settable via CLI env)
# PLAYWRIGHT_BASE_URL="http://localhost:5000"

# -----------------------------------------------------------------------------
# Image Generation (optional — defaults work for most testing)
# -----------------------------------------------------------------------------

# Image provider: 'svg-llm' (default), 'openrouter', or 'stability'
# IMAGE_PROVIDER="svg-llm"

# Stability AI key — only needed if IMAGE_PROVIDER=stability
# STABILITY_API_KEY=""

# Image model overrides (optional)
# OPENROUTER_IMAGE_MODEL="google/gemini-3.1-pro-preview"
# OPENROUTER_SVG_MODEL="google/gemini-3.1-pro-preview"
# IMAGE_GENERATION_TIMEOUT=15000
# MAX_IMAGES_PER_LESSON=4

# Comma-separated fallback model chains (optional)
# SVG_MODEL_FALLBACKS=""
# IMAGE_MODEL_FALLBACKS=""

# -----------------------------------------------------------------------------
# Feature Flags (optional — sensible defaults for testing)
# -----------------------------------------------------------------------------

# Set to 0 to disable AI features (useful for UI-only tests)
# USE_AI=1

# Enable/disable stats collection
# ENABLE_STATS=1

# Image generation toggles
# ENABLE_OPENROUTER_IMAGES=1
# ENABLE_SVG_LLM=1
# ENABLE_STABILITY_FALLBACK=0

# -----------------------------------------------------------------------------
# Bittensor (optional — only if LLM_PROVIDER=bittensor)
# -----------------------------------------------------------------------------

# BITTENSOR_API_KEY=""
# BITTENSOR_SUBNET_1_URL="https://archive.opentensor.ai/graphql"
# BITTENSOR_WALLET_NAME=""
# BITTENSOR_WALLET_HOTKEY=""
# ENABLE_BITTENSOR_SUBNET_1=0
# BITTENSOR_FALLBACK_ENABLED=1

# -----------------------------------------------------------------------------
# Perplexity (optional — only if LLM_PROVIDER=perplexity)
# -----------------------------------------------------------------------------

# PERPLEXITY_API_KEY=""
